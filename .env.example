# --- LLM provider (any OpenAI-compatible endpoint) ------------------------
# Default: Groq — free API key from https://console.groq.com
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=your_groq_api_key_here
MODEL=llama-3.3-70b-versatile

# --- Alternative free backends (uncomment one block to use it) ------------
# Ollama (fully local, no key needed — use any placeholder for LLM_API_KEY):
#   Install from https://ollama.com, then: ollama pull llama3.1
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# MODEL=llama3.1
#
# Google Gemini (free tier — key from https://aistudio.google.com):
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_API_KEY=your_gemini_api_key_here
# MODEL=gemini-2.0-flash

# --- Web search -----------------------------------------------------------
# Free Tavily key from https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# --- Logging --------------------------------------------------------------
LOG_LEVEL=INFO
